# ── Lumora environment ────────────────────────────────────────────────
# Every service is optional: when its keys are missing, Lumora runs that
# service in DEMO MODE (mocked responses) so the whole app stays usable.
# Paste real keys to go live — no code changes needed.

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase (auth + database) — https://supabase.com/dashboard
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Stripe (subscriptions + 7-day trial) — https://dashboard.stripe.com
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PRO=

# fal.ai (Flux image generation) — https://fal.ai/dashboard/keys
FAL_KEY=

# Kling (video generation) — https://klingai.com
KLING_ACCESS_KEY=
KLING_SECRET_KEY=

# Apify (Shopify competitor scraping) — https://console.apify.com
APIFY_TOKEN=

# Anthropic (Claude Vision competitor analysis) — https://console.anthropic.com
ANTHROPIC_API_KEY=

# Shopify Admin API (direct export) — custom app access token
SHOPIFY_STORE_DOMAIN=
SHOPIFY_ADMIN_ACCESS_TOKEN=
