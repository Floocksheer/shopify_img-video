{
  "projectId": "d1388e79-e2c5-4858-a6c2-eed212d758c0",
  "shape": "package",
  "pkg": "lumora",
  "globalName": "Lumora",
  "buildCmd": "node .design-sync/build-css.mjs",
  "tsconfig": ".design-sync/tsconfig.dsync.json",
  "srcDir": "components",
  "cssEntry": ".design-sync/.cache/tw.css",
  "readmeHeader": ".design-sync/conventions.md",
  "extraEntries": ["./.design-sync/shims/ds-frame.tsx"],
  "provider": { "component": "LumoraFrame" },
  "overrides": {
    "Sidebar": { "cardMode": "single", "viewport": "900x620" },
    "Hero": { "cardMode": "single", "viewport": "1200x960" },
    "Navbar": { "cardMode": "single", "viewport": "1100x160" },
    "Footer": { "cardMode": "column" },
    "CTA": { "cardMode": "column" },
    "FAQ": { "cardMode": "column" },
    "Features": { "cardMode": "column" },
    "HowItWorks": { "cardMode": "column" },
    "PricingTiers": { "cardMode": "column" },
    "Testimonials": { "cardMode": "column" }
  },
  "libOverrides": {
    "dts.mjs": "allow all-caps component names CTA and FAQ through the enum-name heuristic"
  },
  "componentSrcMap": {
    "Button": "components/ui/Button.tsx",
    "Card": "components/ui/Card.tsx",
    "Input": "components/ui/Input.tsx",
    "Badge": "components/ui/Badge.tsx",
    "Skeleton": "components/ui/Skeleton.tsx",
    "SectionHeading": "components/ui/SectionHeading.tsx",
    "Reveal": "components/ui/Reveal.tsx",
    "Logo": "components/marketing/Logo.tsx",
    "LogoMark": "components/marketing/Logo.tsx",
    "Navbar": "components/marketing/Navbar.tsx",
    "Footer": "components/marketing/Footer.tsx",
    "Hero": "components/marketing/Hero.tsx",
    "Features": "components/marketing/Features.tsx",
    "HowItWorks": "components/marketing/HowItWorks.tsx",
    "PricingTiers": "components/marketing/PricingTiers.tsx",
    "Testimonials": "components/marketing/Testimonials.tsx",
    "FAQ": "components/marketing/FAQ.tsx",
    "CTA": "components/marketing/CTA.tsx",
    "AuthForm": "components/auth/AuthForm.tsx",
    "Sidebar": "components/app/Sidebar.tsx",
    "StatCard": "components/app/StatCard.tsx",
    "GenerationGrid": "components/app/GenerationGrid.tsx",
    "UploadDropzone": "components/app/UploadDropzone.tsx",
    "OptionPicker": "components/app/OptionPicker.tsx"
  }
}
